{
  "expo": {
    "name": "fe",
    "slug": "fe",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.quyquang.foodorder"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6f06bbb-c33e-486e-a73e-68762b005dfe"
      }
    }
  }
}
